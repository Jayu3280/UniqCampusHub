@model UniqCampusHub.Models.ExamSchedule

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header text-white" style="background-color:#2c3e50;">
            <h4>📅 Create Exam Schedule</h4>
        </div>

        <div class="card-body">

            <form asp-action="Create">

                <div class="mb-3">
                    <label class="form-label">Exam Date</label>
                    <input asp-for="ExamDate" type="date" class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Subject" class="control-label">Subject</label>
                    <select asp-for="Subject" class="form-control">
                        <option value="">-- Select Subject --</option>
                        <option value="C#">C#</option>
                        <option value="C#(Practical)">C#(Practical)</option>
                        <option value="Java Programming">Java Programming</option>
                        <option value="Java Programming (Practical)">Java Programming (Practical)</option>
                        <option value="Python">Python</option>
                        <option value="Python (Practical)">Python (Practical)</option>
                    </select>
                    <span asp-validation-for="Subject" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label class="form-label">Start Time</label>
                    <input asp-for="StartTime" type="time" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">End Time</label>
                    <input asp-for="EndTime" type="time" class="form-control" />
                </div>

                <button type="submit" class="btn btn-success">
                    ✔ Submit
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    ⬅ Back
                </a>

            </form>

        </div>
    </div>
</div>