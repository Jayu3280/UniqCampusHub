@model IEnumerable<UniqCampusHub.Models.ExamSchedule>

<h2 style="text-align:center; color:#2c3e50;">📅 Exam Timetable</h2>

<table border="1" style="width:100%; border-collapse: collapse;">
    <thead style="background-color:#2c3e50; color:white; text-align:center;">
        <tr>
            <th>Date</th>
            <th>Subject</th>
            <th>Start Time</th>
            <th>End Time</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr style="background-color:#ecf0f1; text-align:center;">
                <td>@item.ExamDate.ToShortDateString()</td>
                <td>@item.Subject</td>
                <td>@item.StartTime</td>
                <td>@item.EndTime</td>
            </tr>
        }
    </tbody>
</table>