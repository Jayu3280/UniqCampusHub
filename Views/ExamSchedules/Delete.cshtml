@model UniqCampusHub.Models.ExamSchedule

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header text-white" style="background-color:#c0392b;">
            <h4>🗑️ Delete Exam Schedule</h4>
        </div>

        <div class="card-body">

            <h5 class="mb-3 text-danger">Are you sure you want to delete this exam schedule?</h5>

            <form asp-action="DeleteConfirmed" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label">Exam Date</label>
                    <input asp-for="ExamDate" type="date" class="form-control" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Subject</label>
                    <input asp-for="Subject" class="form-control" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Start Time</label>
                    <input asp-for="StartTime" type="time" class="form-control" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">End Time</label>
                    <input asp-for="EndTime" type="time" class="form-control" readonly />
                </div>

                <button type="submit" class="btn btn-danger">
                    🗑️ Delete
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    ⬅ Back
                </a>

            </form>

        </div>
    </div>
</div>
