@model UniqCampusHub.Models.ExamSchedule

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header text-white" style="background-color:#2c3e50;">
            <h4>📄 Exam Schedule Details</h4>
        </div>

        <div class="card-body">

            <div class="mb-3">
                <label class="form-label">Exam Date</label>
                <input asp-for="ExamDate" type="date" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label">Subject</label>
                <input asp-for="Subject" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label">Start Time</label>
                <input asp-for="StartTime" type="time" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label">End Time</label>
                <input asp-for="EndTime" type="time" class="form-control" readonly />
            </div>

            <div class="mt-4">
                <a asp-action="Index" class="btn btn-secondary">⬅ Back to List</a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">✏ Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">🗑 Delete</a>
            </div>

        </div>
    </div>
</div>