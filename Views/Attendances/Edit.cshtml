@model UniqCampusHub.Models.Attendance

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit Attendance</h1>

<hr />
<div class="row">
    <div class="col-md-4">

        <form asp-action="Edit">

            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="StudentName"></label>
                <input asp-for="StudentName" class="form-control" />
                <span asp-validation-for="StudentName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="SubjectName"></label>
                <input asp-for="SubjectName" class="form-control" />
                <span asp-validation-for="SubjectName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="AttendanceDate"></label>
                <input asp-for="AttendanceDate" class="form-control" type="datetime-local" />
                <span asp-validation-for="AttendanceDate" class="text-danger"></span>
            </div>

            <div class="form-check">
                <input asp-for="IsPresent" class="form-check-input" />
                <label asp-for="IsPresent"></label>
            </div>

            <br />
            <input type="submit" value="Save" class="btn btn-primary" />

        </form>
    </div>
</div>

<a asp-action="Index">Back to List</a>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}